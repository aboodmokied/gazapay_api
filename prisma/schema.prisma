generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  password     String
  name         String?
  phone        String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  privateKey   PrivateKey?
  devices      Device[]
  transactions Transaction[]
}

model PasswordReset {
  id                    String   @id @default(uuid())
  phone                 String
  passwordResetCode     String
  passwordResetExpires  DateTime
  passwordResetVerified Boolean  @default(false)
  createdAt             DateTime @default(now())

  @@index([phone])
}

model PrivateKey {
  id        String   @id @default(uuid())
  key       String // Symmetric encryption key (e.g. Hex/Base64 of AES-256-GCM key)
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Device {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  publicKey String
  createdAt DateTime @default(now())

  transactions Transaction[]
  usedNonces   UsedNonce[]

  @@index([userId])
}

model Transaction {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId  String
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  content   String
  iv        String
  tag       String
  timestamp DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([deviceId])
}

model UsedNonce {
  id        String   @id @default(uuid())
  nonce     String
  deviceId  String
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([nonce, deviceId])
  @@index([deviceId])
}
